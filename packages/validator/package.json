{
  "name": "@design-md/validator",
  "version": "0.1.0",
  "description": "Lint UI source files against DESIGN.md design tokens — contrast, spacing, fonts.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@design-md/parser": "workspace:*",
    "@design-md/schema": "workspace:*",
    "@babel/parser": "^7.25.0",
    "@babel/traverse": "^7.25.0",
    "@babel/types": "^7.25.0",
    "postcss": "^8.4.47",
    "glob": "^11.0.0",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.20.6",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  }
}
